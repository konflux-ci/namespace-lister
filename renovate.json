{
    "extends": [
        "github>konflux-ci/mintmaker//config/renovate/renovate.json"
    ],
    "enabledManagers": [
        "dockerfile",
        "gomod",
        "tekton",
        "kubernetes",
        "kustomize",
        "tekton"
    ],
    "gomod": {
        "postUpdateOptions": ["gomodTidy"]
    },
    "kubernetes": {
        "fileMatch": [
            ".*.ya?ml$",
        ],
        "schedule": [
            "after 5am on monday"
        ]
    },
}
